[{"comment":"replaced several data-stuff with data-bs-stuff, because bootstrap 5.0 changed it.","content":"<!doctype html>\n<html lang=\"en\">\n    <head>\n        <!-- Required meta tags -->\n        <meta charset=\"utf-8\">\n        <meta name=\"viewport\" content=\"width=device-width, initial-scale=1, shrink-to-fit=no\">\n\n        <link rel=\"icon\" type=\"image/x-icon\" href=\"/images/favicon.ico?v=3\">\n\n        <!-- Bootstrap CSS -->\n        <link rel=\"stylesheet\" href=\"/css/bootstrap.<#if darkmode>cyborg.</#if>min.css\"/>\n        <link rel=\"stylesheet\" href=\"/css/karchan.css?version=${version}\"/>\n        <title>Land of Karchan</title>\n        <!-- Optional JavaScript -->\n        <!-- jQuery first, then Popper.js, then Bootstrap JS -->\n        <script src=\"/js/jquery-3.7.1.min.js\"></script>\n        <script src=\"/js/popper.min.js\"></script>\n        <script src=\"/js/bootstrap.min.js\"></script>\n    </head>\n\n    <body>\n        <div class=\"container-fluid d-none d-sm-block\">\n            <div class=\"d-flex align-items-center\">\n                <a href=\"/\" class=\"d-inline-block\">\n                    <#if isChristmas>\n                        <img class=\"mr-3\" src=\"/images/christmas/santadragon.gif\" alt=\"Santadragon\">\n                    <#else>\n                        <img class=\"mr-3\" src=\"/images/gif/dragon.gif\" alt=\"Dragon\">\n                    </#if>\n                </a>\n                <h1 class=\"mt-0 mb-0\">Land of Karchan</h1>\n            </div>\n        </div>\n\n        <div class=\"container-fluid\">\n            <nav class=\"navbar navbar-expand-lg\">\n                <button class=\"navbar-toggler\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#navbarSupportedContent\" aria-controls=\"navbarSupportedContent\" aria-expanded=\"false\" aria-label=\"Toggle navigation\">\n                    <span class=\"navbar-toggler-icon\"></span>\n                </button>\n                <div class=\"navbar-expand d-block d-sm-none d-flex align-items-center\">\n                    <#if isChristmas>\n                        <img class=\"mr-3\" src=\"/images/christmas/santadragon.gif\" alt=\"Santadragon\">\n                    <#else>\n                        <img class=\"mr-3\" src=\"/images/gif/dragon.gif\" alt=\"Dragon\">\n                    </#if>\n                    <a class=\"navbar-brand\">Land of Karchan</a>\n                </div>\n                <div class=\"collapse navbar-collapse\" id=\"navbarSupportedContent\">\n                    <ul class=\"navbar-nav mr-auto\">\n                        <#list menus as menu>\n                            <#if menu.subMenu?size == 0>\n                                <li class=\"nav-item\">\n                                    <a class=\"nav-link<#if activeMenu == menu.name> active</#if>\" href=\"${menu.url}\">${menu.name}</a>\n                                </li>\n                            <#else>\n                                <li class=\"nav-item dropdown\">\n                                    <a class=\"nav-link dropdown-toggle<#if activeMenu == menu.name> active</#if>\" href=\"${menu.url}\" id=\"${menu.name}Dropdown\" role=\"button\" data-bs-toggle=\"dropdown\" aria-haspopup=\"true\" aria-expanded=\"false\">\n                                        ${menu.name}\n                                    </a>\n                                    <div class=\"dropdown-menu\" aria-labelledby=\"${menu.name}Dropdown\">\n                                        <#list menu.subMenu as subber>\n                                            <#if subber.name == \"--\">\n                                                <div class=\"dropdown-divider\"></div>\n                                            <#else>\n                                                <a class=\"dropdown-item<#if activeMenu == subber.name> active</#if>\" href=\"${subber.url}\">${subber.name}</a>\n                                            </#if>\n                                        </#list>\n                                    </div>\n                                </li>\n                            </#if>\n                        </#list>\n                        <#if user??>\n                            <li class=\"nav-item dropdown\">\n                                <a class=\"nav-link dropdown-toggle\" href=\"/#\" id=\"personalDropdown\" role=\"button\" data-bs-toggle=\"dropdown\" aria-haspopup=\"true\" aria-expanded=\"false\">\n                                    Personal\n                                </a>\n                                <div class=\"dropdown-menu\" aria-labelledby=\"personalDropdown\">\n                                    <#if isPlayer>\n                                        <a class=\"dropdown-item\" href=\"/karchanpersonal-${version}\">Settings</a>\n                                    </#if>\n                                    <#if isDeputy>\n                                        <a class=\"dropdown-item\" href=\"/wiki/Administration.html\">Administration Guide</a>\n                                        <a class=\"dropdown-item\" href=\"/karchanadmin-${version}\">Admin</a>\n                                    </#if>\n                                    <a class=\"dropdown-item\" href=\"/?logout=true\">Log out</a>\n                                </div>\n                            </li>\n                        </#if>\n                    </ul>\n                </div>\n            </nav>\n        </div>\n\n        <#if user??>\n            <div class=\"container-fluid\">\n                <div class=\"alert alert-primary d-none d-sm-block d-flex align-items-center\" role=\"alert\">\n                    <#if isChristmas>\n                        <img class=\"mr-3\" src=\"/images/christmas/sclaus.gif\" alt=\"Santa claus\">\n                    </#if>\n                    <span>Welcome to Karchan, ${user}!</span>\n                    <#if isPlayer>\n                        <span class=\"position-absolute end-0\">\n                            [<a href=\"/karchanpersonal-${version}/play\">Play</a>]\n                            [<a href=\"/karchanpersonal-${version}\">Settings</a>] [<a href=\"/?logout=true\">Log out</a>]\n                        </span>\n                    </#if>\n                </div>\n                <div class=\"alert alert-primary d-block d-sm-none d-flex align-items-center\" role=\"alert\">\n                    <#if isChristmas>\n                        <img class=\"mr-3\" src=\"/images/christmas/sclaus.gif\" alt=\"Santa claus\">\n                    </#if>\n                    <span>Welcome!</span>\n                    <#if isPlayer>\n                        <span class=\"position-absolute end-0\">\n                            [<a href=\"/karchanpersonal-${version}/play\">Play</a>]\n                            [<a href=\"/karchanpersonal-${version}\">Settings</a>] [<a href=\"/?logout=true\">Log out</a>]\n                        </span>\n                    </#if>\n                </div>\n            </div>\n        </#if>\n\n        <div class=\"container-fluid\">\n            <nav aria-label=\"breadcrumb\">\n                <ol class=\"breadcrumb\">\n                    <#list breadcrumbs as breadcrumb>\n                        <li class=\"breadcrumb-item\"><a href=\"${breadcrumb.url}\">${breadcrumb.name}</a></li>\n                    </#list>\n                    <#if lastBreadcrumb??>\n                        <li class=\"breadcrumb-item active\" aria-current=\"page\">${lastBreadcrumb.name}</li>\n                    </#if>\n                </ol>\n            </nav>\n        </div>\n\n        <#if hasNewMail>\n            <div role=\"alert\" aria-live=\"assertive\" aria-atomic=\"true\" class=\"toast\" data-bs-autohide=\"false\">\n                <div class=\"toast\" style=\"position: absolute; top: 20px; right: 30px;\" role=\"alert\" aria-live=\"assertive\" aria-atomic=\"true\">\n                    <div class=\"toast-header\">\n                        <img src=\"/favicon.ico\" class=\"rounded mr-2\" alt=\"Karchan\">\n                        <strong class=\"mr-auto\">Message</strong>\n                        <button type=\"button\" class=\"ml-2 mb-1 close\" data-bs-dismiss=\"toast\" aria-label=\"Close\">\n                            <span aria-hidden=\"true\">&times;</span>\n                        </button>\n                    </div>\n                    <div class=\"toast-body\">\n                        You have new <a href=\"/karchanpersonal-${version}/mail\">mail</a>.\n                    </div>\n                </div>\n            </div>\n\n            <script>\n                $(document).ready(function() {\n                    $('.toast').toast({\n                        'autohide': false\n                    });\n\n                    $('.toast').toast('show');\n                });\n            </script>\n        </#if>\n    </body>\n</html>\n","created":"2019-03-31T08:05:22","editor":"Victoria","id":1,"modified":"2024-11-05T21:22:57","name":"header","version":5.0}]
